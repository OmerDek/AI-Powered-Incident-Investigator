@inject IAiAnalysisClient AiClient
@inject ILogFileService LogFileService
@inject IJSRuntime JS

<MudCard Class="pa-4">
    <MudCardContent>
        <MudText Typo="Typo.h6" Class="mb-2">AI Investigation Summary</MudText>

        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.AutoAwesome"
                   Disabled="@(_loading || SelectedFiles.Count == 0)"
                   OnClick="GenerateAnalysis">
            @(_loading ? "Analyzing..." : "Generate AI Analysis")
        </MudButton>

        @if (SelectedFiles.Count == 0 && !_loading && _result is null)
        {
            <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Secondary" Style="display:block;">
                Select one or more log files above to enable analysis.
            </MudText>
        }

        @if (_loading)
        {
            <div class="d-flex align-center mt-4">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                <MudText>Analyzing logs... Generating AI insights...</MudText>
            </div>
        }
        else if (_error)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                Unable to generate AI analysis. Please try again later.
            </MudAlert>
        }
        else if (_result is not null)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-4">Incident Overview</MudText>
            <MudText>@_result.IncidentOverview</MudText>

            <MudText Typo="Typo.subtitle1" Class="mt-4">Investigation Findings</MudText>
            <MudList T="string" Dense="true">
                @foreach (var finding in _result.InvestigationFindings)
                {
                    <MudListItem T="string">@finding</MudListItem>
                }
            </MudList>

            <MudText Typo="Typo.subtitle1" Class="mt-4">Likely Root Cause</MudText>
            <MudText>@_result.LikelyRootCause</MudText>

            <div class="d-flex mt-4" style="gap: 32px;">
                <div>
                    <MudText Typo="Typo.subtitle1">Confidence</MudText>
                    <MudChip T="string" Color="Color.Success">@_result.Confidence%</MudChip>
                </div>
                @if (!string.IsNullOrEmpty(_result.Severity))
                {
                    <div>
                        <MudText Typo="Typo.subtitle1">Severity</MudText>
                        <MudChip T="string" Color="@SeverityColor(_result.Severity)">@_result.Severity</MudChip>
                    </div>
                }
            </div>

            @if (_result.Timeline.Count > 0)
            {
                <MudText Typo="Typo.subtitle1" Class="mt-4">Timeline</MudText>
                <MudList T="string" Dense="true">
                    @foreach (var entry in _result.Timeline)
                    {
                        <MudListItem T="string"><b>@entry.Timestamp</b> &mdash; @entry.Event</MudListItem>
                    }
                </MudList>
            }

            <MudText Typo="Typo.subtitle1" Class="mt-4">Evidence</MudText>
            <MudList T="string" Dense="true">
                @foreach (var evidence in _result.Evidence)
                {
                    <MudListItem T="string">@evidence</MudListItem>
                }
            </MudList>

            <MudText Typo="Typo.subtitle1" Class="mt-4">Recommended Actions</MudText>
            <MudList T="string" Dense="true">
                @foreach (var action in _result.RecommendedActions)
                {
                    <MudListItem T="string">@action</MudListItem>
                }
            </MudList>

            <MudText Typo="Typo.subtitle1" Class="mt-4">Relevant Components</MudText>
            <div class="mt-1">
                @foreach (var component in _result.RelevantComponents)
                {
                    <MudChip T="string" Class="mr-1">@component</MudChip>
                }
            </div>

            <div class="mt-4">
                <MudButton Variant="Variant.Outlined" OnClick="GenerateAnalysis" Class="mr-2">Refresh</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="ExportJson">Export Investigation Summary</MudButton>
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public AgentInfo Agent { get; set; } = null!;

    [Parameter, EditorRequired]
    public HashSet<string> SelectedFiles { get; set; } = new();

    private bool _loading;
    private bool _error;
    private InvestigationSummary? _result;

    private async Task GenerateAnalysis()
    {
        if (SelectedFiles.Count == 0)
        {
            return;
        }

        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            var logFiles = new List<LogFileContent>();
            foreach (var fileName in SelectedFiles)
            {
                var content = await LogFileService.GetLogFileContentAsync(Agent.AgentName, fileName);
                logFiles.Add(new LogFileContent { FileName = fileName, Content = content });
            }

            _result = await AiClient.AnalyzeAsync(Agent, logFiles);
        }
        catch
        {
            _error = true;
        }

        _loading = false;
        StateHasChanged();
    }

    private async Task ExportJson()
    {
        if (_result is null)
        {
            return;
        }

        var export = new
        {
            agentName = Agent.AgentName,
            clientVersion = Agent.ClientVersion,
            configVersion = Agent.ConfigVersion,
            investigationSummary = _result
        };

        var json = System.Text.Json.JsonSerializer.Serialize(export, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "investigation-summary.json", json);
    }

    private Color SeverityColor(string severity) => severity.ToLowerInvariant() switch
    {
        "critical" or "high" => Color.Error,
        "medium" => Color.Warning,
        "low" => Color.Success,
        _ => Color.Default
    };
}
