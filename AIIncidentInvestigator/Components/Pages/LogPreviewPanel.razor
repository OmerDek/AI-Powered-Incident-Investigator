@if (!string.IsNullOrEmpty(FileName))
{
    <MudCard Class="mb-4">
        <MudCardContent>
            <MudText Typo="Typo.h6">@FileName</MudText>
            <MudDivider Class="my-2" />
            <pre style="white-space: pre-wrap; font-family: monospace; margin: 0; max-height: 420px; overflow-y: auto; font-size: 0.8rem; line-height: 1.4; padding-right: 8px;">@Content</pre>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter]
    public string? FileName { get; set; }

    [Parameter]
    public string? Content { get; set; }
}
